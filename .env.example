# Application Configuration
PORT=8080
ENV=development
LOG_LEVEL=info

# Database
DATABASE_URI=postgres://user:password@localhost:5432/bro_db?sslmode=disable

# Security
JWT_SECRET=your-secret-key-change-in-production

# Service-to-service authentication (Sigil)
# Required in non-development environments
SIGIL_SECRET=your-sigil-secret-min-32-chars-change-in-production
ALLOWED_SERVICES=gateway

# Startup
STARTUP_TIMEOUT_SEC=30
